# Valyu API Keys (comma-separated for multi-key rotation)
VALYU_API_KEYS=val_your_key_here

# Optional: Valyu API base URL (default: https://api.valyu.ai/v1)
# VALYU_BASE_URL=https://api.valyu.ai/v1

# Optional: Seconds between offline-key retry attempts (default: 300)
# KEY_RETRY_INTERVAL_SECONDS=300

# Optional: HTTP request timeout (default: 120)
# REQUEST_TIMEOUT_SECONDS=120

# Optional: MCP HTTP server host/port (default: 0.0.0.0:8000)
# FASTMCP_HOST=0.0.0.0
# FASTMCP_PORT=8012

# Optional: Log level (default: INFO)
# LOG_LEVEL=INFO
